datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model User {
    id        Int      @id @default(autoincrement())
    name      String   @db.VarChar(50)
    email     String   @unique @db.VarChar(100)
    password  String   @db.VarChar(255)
    birthDate DateTime @db.Date()
}
